config DACTYL_BATT_LED
    bool "Green battery-level indicator LED"
    default y
    depends on DT_HAS_GPIO_LEDS_ENABLED
    help
      Blink a single discrete LED to indicate the local battery state of
      charge: 3 blinks = good, 2 = medium, 1 = low, and a repeating blink
      below the critical level. Shown once after boot and on demand via the
      &batt_led_show keymap behavior. Both halves carry their own LED and show
      their own battery; each shield overlay defines a `batt-led` gpio-leds
      node, so this is enabled on both halves.

if DACTYL_BATT_LED

config DACTYL_BATT_LED_LEVEL_HIGH
    int "Battery percentage above which 3 blinks are shown"
    default 90

config DACTYL_BATT_LED_LEVEL_LOW
    int "Battery percentage above which 2 blinks are shown (at or below = 1 blink)"
    default 20

config DACTYL_BATT_LED_LEVEL_CRITICAL
    int "Battery percentage at or below which the low-battery heartbeat runs"
    default 10

config DACTYL_BATT_LED_CRITICAL_INTERVAL_SEC
    int "Seconds between blinks of the critical-battery heartbeat"
    default 30

config DACTYL_BATT_LED_BLINK_MS
    int "LED on/off duration per blink half-step, in milliseconds"
    default 200

endif
